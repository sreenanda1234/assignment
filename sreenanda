#include <stdio.h>
#include <string.h>

struct Process {
    char pid[10];
    int at, bt, wt, tat, ct;
    int is_completed;
};

int main() {
    int n;
    // Input number of processes
    if (scanf("%d", &n) != 1) return 0;

    struct Process p[n];
    for (int i = 0; i < n; i++) {
        scanf("%s %d %d", p[i].pid, &p[i].at, &p[i].bt);
        p[i].is_completed = 0;
    }

    int completed = 0, current_time = 0;
    float sum_wt = 0, sum_tat = 0;

    while (completed != n) {
        int idx = -1;
        int min_bt = 1e9; // Initialize with a large value

        // Find the process with the minimum burst time among those that have arrived
        for (int i = 0; i < n; i++) {
            if (p[i].at <= current_time && p[i].is_completed == 0) {
                if (p[i].bt < min_bt) {
                    min_bt = p[i].bt;
                    idx = i;
                }
                // If burst times are equal, tie-breaker: earlier arrival time
                if (p[i].bt == min_bt) {
                    if (idx != -1 && p[i].at < p[idx].at) {
                        idx = i;
                    }
                }
            }
        }

        if (idx != -1) {
            // Process found: Update times
            p[idx].ct = current_time + p[idx].bt;
            p[idx].tat = p[idx].ct - p[idx].at;
            p[idx].wt = p[idx].tat - p[idx].bt;

            sum_wt += p[idx].wt;
            sum_tat += p[idx].tat;
            p[idx].is_completed = 1;
            completed++;
            current_time = p[idx].ct;
        } else {
            // No process has arrived yet, advance clock
            current_time++;
        }
    }

    // Output results matching your requested format
    printf("Waiting Time:\n");
    for (int i = 0; i < n; i++) {
        printf("%s %d\n", p[i].pid, p[i].wt);
    }

    printf("Turnaround Time:\n");
    for (int i = 0; i < n; i++) {
        printf("%s %d\n", p[i].pid, p[i].tat);
    }

    printf("Average Waiting Time: %.2f\n", sum_wt / n);
    printf("Average Turnaround Time: %.2f\n", sum_tat / n);

    return 0;
}
